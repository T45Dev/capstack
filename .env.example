# Copy to .env (same directory as docker-compose.yml) and fill in.
# .env is gitignored; docker compose auto-loads it and substitutes the
# values into the capstack service environment.

# HTTP Basic Auth gate for the whole app. Set BOTH to require a login on
# every request (public tunnel + LAN). Leave unset/blank to disable the gate.
NUXT_BASIC_AUTH_USER=
NUXT_BASIC_AUTH_PASS=
